@using E_Commerce.Models
@model OrderDetailsModel
@{
    ViewBag.Title = "Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content">
    <div>
        <h4>Sipariş Bilgileri</h4>
        <hr />

        <div class="row">
            @if (TempData["message"] != null)
            {
                <div class="alert alert-success alert-dismissable">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4>	<i class="icon fa fa-check"></i> BAŞARILI!</h4>
                    Sipariş durumu güncellendi 
                </div>
            }
        </div>

        <dl class="dl-horizontal">
            <dt>
                Sipariş Durumu
            </dt>

            <dd>
                @using (Html.BeginForm("UpdateOrderState", "Order", FormMethod.Post))
                {
                    @Html.HiddenFor(x=>x.OrderId)
                    @Html.EnumDropDownListFor(i => i.OrderState, "Sipariş Durumunu Seç", new { @class = "form-control" })

                    <button type="submit" class="btn btn-primary">Güncelle</button>
                }

            </dd>

            <dt>
                Kullanıcı Adı
            </dt>

            <dd>
                @Html.DisplayFor(Model => Model.UserName)
            </dd>

            <dt>
                Sipariş Numarası
            </dt>

            <dd>
                @Html.DisplayFor(Model => Model.OrderNumber)
            </dd>

            <dt>
                Toplam Tutar
            </dt>

            <dd>
                @Html.DisplayFor(Model => Model.Total)
            </dd>

            <dt>
                Sipariş Tarihi
            </dt>

            <dd>
                @Html.DisplayFor(Model => Model.OrderDate)
            </dd>

            <dt>
                Adres
            </dt>

            <dd>
                Adres:  @Html.DisplayFor(Model => Model.Address) <br />
                Mahalle:  @Html.DisplayFor(Model => Model.Neighbourhood) <br />
                İlçe:  @Html.DisplayFor(Model => Model.District) <br />
                Şehir:  @Html.DisplayFor(Model => Model.City) <br />
                Posta Kodu:  @Html.DisplayFor(Model => Model.PostCode) <br />
            </dd>

        </dl>
    </div>

    <table class="table table-bordered table-condensed">
        <thead>
            <tr>
                <th>Resim</th>
                <th>Ürün Adı</th>
                <th>Toplam Tutar(₺) </th>
                <th>Adet</th>

                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderLines)
            {
                <tr>
                    <td><img src="~/Content/Images/@item.Image" height="75" width="75" /> </td>
                    <td>@item.ProductName</td>
                    <td>@item.Price</td>
                    <td>@item.Quantity</td>
                    <td><a href="/Home/ProductDetails/@item.ProductId" class="btn btn-success" target="_blank">Ürün Detay</a></td>
                </tr>
            }
        </tbody>
    </table><br>

</section>

